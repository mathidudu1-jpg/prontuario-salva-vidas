# Supabase — copie estes nomes para o Vercel (Project Settings → Environment Variables)
# e cole os valores do seu projeto (Supabase → Project Settings → API).
# Localmente, crie um arquivo .env.local com estas duas linhas.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica
